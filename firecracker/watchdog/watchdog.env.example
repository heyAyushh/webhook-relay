# Copy to /etc/firecracker/watchdog.env and customize.

# Watchdog + heartbeat log location. If unwritable, scripts fall back to /tmp/firecracker-watchdog.
FIRECRACKER_WATCHDOG_LOG_DIR=/var/log/firecracker/watchdog
FIRECRACKER_WATCHDOG_FALLBACK_LOG_DIR=/tmp/firecracker-watchdog
FIRECRACKER_WATCHDOG_LOG_FILE_NAME=watchdog.log

# Inventory source (script loads /etc/firecracker/brokers.json through this helper by default).
# FIRECRACKER_BROKER_INVENTORY_SCRIPT=/opt/hook-serve/firecracker/runtime/broker_inventory.sh

# Relay VM checks.
FIRECRACKER_WATCHDOG_RELAY_SERVICE=firecracker@relay.service
FIRECRACKER_WATCHDOG_RELAY_SOCKET=/tmp/relay-fc.sock
FIRECRACKER_WATCHDOG_RELAY_VM_IP=172.30.0.20
FIRECRACKER_WATCHDOG_RELAY_VM_PORT=8080
# Optional health URL. Leave empty to disable URL health probing.
# FIRECRACKER_WATCHDOG_RELAY_HEALTH_URL=http://172.30.0.20:8080/health
FIRECRACKER_WATCHDOG_RELAY_HEALTH_EXPECT_SUBSTRING=ok
FIRECRACKER_WATCHDOG_RELAY_HEALTH_RESTART_SERVICE=firecracker@relay.service

# Required host services checked each cycle.
FIRECRACKER_WATCHDOG_REQUIRED_SERVICES=firecracker-network.service,firecracker@relay.service

# Broker checks.
FIRECRACKER_WATCHDOG_BROKER_SERVICE_TEMPLATE=firecracker@%s.service
FIRECRACKER_WATCHDOG_BROKER_SOCKET_TEMPLATE=/tmp/%s-fc.sock
FIRECRACKER_WATCHDOG_BROKER_PORT=9092

# Optional helpers and feature switches.
# FIRECRACKER_WATCHDOG_HEARTBEAT_SCRIPT=/opt/hook-serve/firecracker/watchdog/heartbeat.sh
# FIRECRACKER_WATCHDOG_ALERT_HELPER=/opt/hook-serve/firecracker/watchdog/alert.sh
FIRECRACKER_WATCHDOG_ENABLE_KAFKA_METADATA_CHECK=false
FIRECRACKER_WATCHDOG_RESTART_DELAY_SECONDS=5

# Optional extra check for external tunnel listener health.
# FIRECRACKER_WATCHDOG_CHISEL_HOST_PORT=127.0.0.1:8080
# FIRECRACKER_WATCHDOG_CHISEL_SERVICE=chisel.service

# Heartbeat-only extras.
# FIRECRACKER_HEARTBEAT_SERVICE_LIST=firecracker@relay.service
# FIRECRACKER_HEARTBEAT_EXTERNAL_URL=https://example.com/health
